# Validate required config keys
validate_config()

if DS_TYPE == "era5":
    ERA5_CIRCULATION_FILES = get_era5_files("preprocess_circulation_era5")
    ERA5_IMPACT_VARIABLES_FILES = get_era5_files("preprocess_impact_variables_era5")
    TMP_BIAS_CORRECTION_REFORECASTS = []
    TMP_BIAS_CORRECTION_ERA5 = []
    IMPACT_VARIABLES_WG = expand(
        os.path.join(
            get_preprocessed_dir("impact_variables", "era5"),
            "combined_{hash_preprocess_impact_variables_era5}.zarr",
        ),
        hash_preprocess_impact_variables_era5=get_params_hash(
            f"preprocess_impact_variables_era5"
        ),
    )[0]
elif DS_TYPE == "reforecasts":
    if config["use_bias_corrected"]:
        assert (
            config["lead_time_days_low"] is not None
            and config["lead_time_days_high"] is not None
        ), "lead_time_days_low and lead_time_days_high may not be empty."
        TMP_BIAS_CORRECTION_REFORECASTS = get_bias_correction_files("reforecasts")
        TMP_BIAS_CORRECTION_ERA5 = get_bias_correction_files("era5")
        ERA5_CIRCULATION_FILES = get_era5_files("preprocess_circulation_era5")
        ERA5_IMPACT_VARIABLES_FILES = get_era5_files("preprocess_impact_variables_era5")
        IMPACT_VARIABLES_WG = expand(
            os.path.join(
                get_preprocessed_dir("impact_variables", "reforecasts"),
                "combined-corrected_{hash_era5}_{hash_re}_{hash_compute_bias}_"
                + "{hash_correct_bias}.zarr",
            ),
            var_type="impact_variables",
            hash_era5=get_params_hash(f"preprocess_impact_variables_era5"),
            hash_re=get_params_hash(f"preprocess_impact_variables_reforecasts"),
            hash_compute_bias=get_params_hash(f"compute_bias"),
            hash_correct_bias=get_params_hash("correct_bias"),
        )[0]

    else:
        TMP_BIAS_CORRECTION_REFORECASTS = []
        TMP_BIAS_CORRECTION_ERA5 = []
        ERA5_CIRCULATION_FILES = []
        ERA5_IMPACT_VARIABLES_FILES = get_era5_files("preprocess_impact_variables_era5")
        IMPACT_VARIABLES_WG = expand(
            os.path.join(
                get_preprocessed_dir("impact_variables", "reforecasts"),
                "combined_{hash_preprocess_impact_variables_reforecasts}.zarr",
            ),
            hash_preprocess_impact_variables_reforecasts=get_params_hash(
                "preprocess_impact_variables_reforecasts"
            ),
        )[0]
else:
    raise ValueError(f"Invalid value for dataset_type: {DS_TYPE}")

